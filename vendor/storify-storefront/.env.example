# انسخ هذا الملف إلى .env (أو انسخ المحتوى إلى .env) ثم أعد تشغيل السيرفر: npm run dev
# Copy this file to .env (or copy contents to .env) then restart: npm run dev

# API: للتطوير اتركه بدون قيمة (أو /api) لاستخدام الـ proxy → الطلبات تذهب للـ backend تلقائياً
# For production set the full API URL (e.g. https://api.yourdomain.com/api)
# VITE_API_URL=/api
VITE_API_URL=

# Authentication Configuration
# Use cookie-based authentication (recommended, more secure)
VITE_USE_COOKIE_AUTH=true

# Legacy token storage in localStorage (set to false after migration)
# Only set to true if you need backward compatibility during migration
VITE_LEGACY_TOKEN_STORAGE=false

# Optional: Gemini API Key (if using AI features)
# GEMINI_API_KEY=your-gemini-api-key-here

# Development: عرض متجر معيّن مباشرة على localhost (الطلبات ترسل X-Store-Id)
# المتجر يجب أن يكون موجوداً في النظام؛ لطريقة دفع شام كاش: ثبّت التكامل وأدخل معرف المحفظة
# Leave empty or remove in production
#VITE_DEV_STORE_ID=demo-dev-store