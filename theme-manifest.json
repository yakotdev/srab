        "show_wishlist": {
          "type": "select",
          "label": "إظهار زر المفضلة",
          "options": [
            { "value": "true", "label": "نعم" },
            { "value": "false", "label": "لا" }
          ],
          "default": "true"
        },
        "show_share": {
          "type": "select",
          "label": "إظهار زر المشاركة",
          "options": [
            { "value": "true", "label": "نعم" },
            { "value": "false", "label": "لا" }
          ],
          "default": "true"
        },
        "trust_badges": {
          "type": "repeater",
          "label": "مميزات المنتج (Badges)",
