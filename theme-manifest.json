{
  "name": "Srab",
  "version": "1.0.2",
  "manifestVersion": 1,
  "entry": "assets/main.js",
  "languages": [
    "ar",
    "en",
    "fr"
  ],
  "assets": {
    "locales_ar": "locales/ar.json",
    "locales_en": "locales/en.json",
    "locales_fr": "locales/fr.json"
  },
  "themeSettingsGroups": [
    {
      "id": "layout",
      "label": "التخطيط",
      "description": "شكل الواجهة العام",
      "order": 0
    },
    {
      "id": "fonts",
      "label": "الخطوط",
      "description": "خطوط النصوص والعناوين",
      "order": 1
    },
    {
      "id": "colors",
      "label": "مخططات الألوان",
      "description": "ألوان الثيم المتاحة لكل قسم",
      "order": 2
    },
    {
      "id": "social",
      "label": "وسائل التواصل",
      "description": "روابط الحسابات الاجتماعية",
      "order": 3
    },
    {
      "id": "whatsapp",
      "label": "واتساب",
      "description": "زر الواتساب العائم",
      "order": 4
    },
    {
      "id": "products",
      "label": "المنتجات والسلة",
      "description": "عرض الصور وبطاقات المنتج ونمط السلة",
      "order": 5
    }
  ],
  "themeSettingsSchema": {
    "borderRadius": {
      "group": "layout",
      "type": "select",
      "label": "انحناء الزوايا",
      "options": [
        {
          "value": "0px",
          "label": "حادة"
        },
        {
          "value": "8px",
          "label": "صغيرة"
        },
        {
          "value": "16px",
          "label": "متوسطة"
        },
        {
          "value": "24px",
          "label": "كبيرة"
        },
        {
          "value": "40px",
          "label": "دائرية"
        }
      ],
      "default": "24px"
    },
    "fontFamily": {
      "group": "fonts",
      "type": "google_font",
      "label": "خط النصوص (الجسم)",
      "description": "اختر خط النصوص من قائمة الخطوط العربية والعالمية.",
      "default": "Almarai"
    },
    "fontFamilyHeadings": {
      "group": "fonts",
      "type": "google_font",
      "label": "خط العناوين",
      "description": "يمكن أن يطابق خط النصوص أو يختلف لتمييز العناوين.",
      "default": "Almarai"
    },
    "social_facebook": {
      "group": "social",
      "type": "text",
      "label": "رابط فيسبوك",
      "default": ""
    },
    "social_instagram": {
      "group": "social",
      "type": "text",
      "label": "رابط انستقرام",
      "default": ""
    },
    "social_twitter": {
      "group": "social",
      "type": "text",
      "label": "رابط تويتر",
      "default": ""
    },
    "social_youtube": {
      "group": "social",
      "type": "text",
      "label": "رابط يوتيوب",
      "default": ""
    },
    "social_linkedin": {
      "group": "social",
      "type": "text",
      "label": "رابط لينكدان",
      "default": ""
    },
    "social_pinterest": {
      "group": "social",
      "type": "text",
      "label": "رابط بانترست",
      "default": ""
    },
    "social_tiktok": {
      "group": "social",
      "type": "text",
      "label": "رابط تيكتوك",
      "default": ""
    },
    "whatsapp_enable": {
      "group": "whatsapp",
      "type": "select",
      "label": "تفعيل زر الواتساب العائم",
      "options": [
        { "value": "true", "label": "تفعيل" },
        { "value": "false", "label": "إيقاف" }
      ],
      "default": "false"
    },
    "whatsapp_number": {
      "group": "whatsapp",
      "type": "text",
      "label": "رقم الواتساب (مع رمز الدولة بدون +)",
      "default": "",
      "description": "مثال: 966500000000"
    },
    "whatsapp_message": {
      "group": "whatsapp",
      "type": "textarea",
      "label": "رسالة الواتساب التلقائية",
      "default": "مرحباً، أود الاستفسار عن المنتجات."
    },
    "color_schemes": {
      "group": "colors",
      "type": "color_schemes",
      "label": "مخططات الألوان",
      "description": "كل ألوان الواجهة (خلفية، نص، أزرار، روابط…) مرتبطة بالمخطط الذي تختاره لكل قسم. الخطوط تُضبط من قسم «الخطوط» أعلاه."
    },
    "product_image_aspect": {
      "group": "products",
      "type": "select",
      "label": "نسبة صندوق صورة المنتج",
      "description": "تُطبَّق على بطاقات المنتج، صورة المنتج الرئيسية، المعاينة السريعة، نتائج البحث، وصور السلة. الصور المصغّرة في معرض المنتج تبقى مربعة لتسهيل التصفح.",
      "options": [
        { "value": "1_1", "label": "1:1 (مربع)" },
        { "value": "4_5", "label": "4:5 (وضعية أزياء — الافتراضي)" },
        { "value": "3_4", "label": "3:4" },
        { "value": "4_3", "label": "4:3" },
        { "value": "16_9", "label": "16:9 (عرضي)" }
      ],
      "default": "4_5"
    },
    "product_image_fit": {
      "group": "products",
      "type": "select",
      "label": "ملء إطار صورة المنتج",
      "description": "«قص لملء الإطار» يملأ المساحة وقد يقطع أطراف الصورة. «إظهار الصورة كاملة» يحافظ على الصورة داخل الإطار مع فراغات إن لزم.",
      "options": [
        { "value": "cover", "label": "قص لملء الإطار" },
        { "value": "contain", "label": "إظهار الصورة كاملة داخل الإطار" }
      ],
      "default": "cover"
    },
    "cart_style": {
      "group": "products",
      "type": "select",
      "label": "نمط السلة",
      "description": "اختر التصميم المناسب لعرض السلة الجانبية للمشترين.",
      "options": [
        { "value": "classic", "label": "درج جانبي كلاسيكي" },
        { "value": "floating_glass", "label": "بطاقة زجاجية عائمة" },
        { "value": "bottom_panel", "label": "لوحة سفلية حديثة" }
      ],
      "default": "classic"
    },
    "product_card_style": {
      "group": "products",
      "type": "select",
      "label": "نمط بطاقة المنتج",
      "description": "اختر تصميم عرض بطاقات المنتجات في الصفحة الرئيسية وصفحة المتجر.",
      "options": [
        { "value": "classic", "label": "كلاسيكي فاخر" },
        { "value": "glass_modern", "label": "عصري زجاجي" },
        { "value": "minimal", "label": "بسيط هادئ" }
      ],
      "default": "classic"
    }
  },
  "sections": [
    {
      "id": "header",
      "name": "الهيدر",
      "component": "HEADER",
      "group": "header_group",
      "contentSchema": {
        "color_scheme": {
          "type": "select",
          "label": "مخطط الألوان",
          "optionsFrom": "color_schemes",
          "default": "scheme-light"
        },
        "sticky": {
          "type": "select",
          "label": "تثبيت الهيدر",
          "options": [
            {
              "value": "true",
              "label": "نعم"
            },
            {
              "value": "false",
              "label": "لا"
            }
          ],
          "default": "true"
        },
        "show_top_bar": {
          "type": "select",
          "label": "إظهار الشريط العلوي",
          "options": [
            { "value": "true", "label": "نعم" },
            { "value": "false", "label": "لا" }
          ],
          "default": "true"
        },
        "top_bar_text": {
          "type": "text",
          "label": "نص الشريط العلوي",
          "default": "شحن مجاني للطلبات الأكثر من 200 ريال! 🚚"
        },
        "height": {
          "type": "select",
          "label": "ارتفاع الشريط",
          "options": [
            { "value": "compact", "label": "مضغوط" },
            { "value": "normal", "label": "عادي (Srab)" },
            { "value": "large", "label": "عالي" }
          ],
          "default": "normal"
        },
        "show_logo": {
          "type": "select",
          "label": "إظهار الشعار",
          "options": [
            { "value": "true", "label": "نعم" },
            { "value": "false", "label": "لا" }
          ],
          "default": "true"
        },
        "show_wishlist": {
          "type": "select",
          "label": "إظهار المفضلة",
          "options": [
            {
              "value": "true",
              "label": "نعم"
            },
            {
              "value": "false",
              "label": "لا"
            }
          ],
          "default": "true"
        },
        "show_cart": {
          "type": "select",
          "label": "إظهار السلة",
          "options": [
            {
              "value": "true",
              "label": "نعم"
            },
            {
              "value": "false",
              "label": "لا"
            }
          ],
          "default": "true"
        },
        "menu": {
          "type": "menu",
          "label": "قائمة الهيدر"
        }
      }
    },
    {
      "id": "hero_slider",
      "name": "قسم البطل الرئيسي (شرائح)",
      "component": "HERO_SLIDER",
      "group": "template_group",
      "contentSchema": {
        "color_scheme": {
          "type": "select",
          "label": "مخطط الألوان",
          "translatable": false,
          "optionsFrom": "color_schemes",
          "default": "scheme-light"
        },
        "layout_style": {
          "type": "select",
          "label": "نمط العرض",
          "translatable": false,
          "options": [
            { "value": "classic", "label": "كلاسيكي (صورة كاملة)" },
            { "value": "split", "label": "منقسم (صورة ونص)" },
            { "value": "minimal", "label": "بسيط (تركيز على النص)" }
          ],
          "default": "classic"
        },
        "autoplay": {
          "type": "select",
          "label": "تشغيل تلقائي",
          "translatable": false,
          "options": [
            { "value": "true", "label": "نعم" },
            { "value": "false", "label": "لا" }
          ],
          "default": "true"
        },
        "interval": {
          "type": "number",
          "label": "مدة العرض (بالثواني)",
          "default": 5
        },

        "slides": {

          "type": "repeater",
          "label": "الشرائح",
          "itemLabel": "شريحة",
          "minItems": 1,
          "maxItems": 10,
          "fields": {
            "image": { "type": "image", "label": "الصورة" },
            "title": { "type": "text", "label": "العنوان الرئيسي", "default": "أناقة بلا حدود" },
            "subtitle": { "type": "textarea", "label": "الوصف", "default": "اكتشف أحدث صيحات الموضة والمنتجات الحصرية لدينا." },
            "buttonText": { "type": "text", "label": "نص الزر", "default": "تسوق الآن" },
            "link": { "type": "link", "label": "رابط الزر", "default": "/shop" },
            "alignment": {
              "type": "select",
              "label": "محاذاة النص",
              "options": [
                { "value": "left", "label": "يسار" },
                { "value": "center", "label": "وسط" },
                { "value": "right", "label": "يمين" }
              ],
              "default": "center"
            },
            "overlayOpacity": {
              "type": "text",
              "label": "شفافية التعتيم (0-1)",
              "default": "0.3"
            }
          }
        }
      }
    },
    {
      "id": "categories",
      "name": "الأقسام",
      "component": "CATEGORIES",
      "group": "template_group",
      "contentSchema": {
        "color_scheme": {
          "type": "select",
          "label": "مخطط الألوان",
          "optionsFrom": "color_schemes",
          "default": "scheme-light"
        },
        "title": {
          "type": "text",
          "label": "العنوان",
          "default": "الأقسام"
        },
        "subtitle": {
          "type": "text",
          "label": "العنوان الفرعي",
          "default": "استكشف الأقسام"
        },
        "layout_style": {
          "type": "select",
          "label": "نمط العرض",
          "options": [
            {
              "value": "grid",
              "label": "شبكة تقليدية"
            },
            {
              "value": "circles",
              "label": "دوائر ناعمة"
            },
            {
              "value": "bento",
              "label": "بينتو (Bento)"
            }
          ],
          "default": "grid"
        },
        "padding_top": {
          "type": "text",
          "label": "الهامش العلوي",
          "default": "80px"
        },
        "padding_bottom": {
          "type": "text",
          "label": "الهامش السفلي",
          "default": "80px"
        },
        "enable_horizontal_scroll": {
          "type": "select",
          "label": "تفعيل سلايدر سحب أفقي",
          "description": "يعمل مع شبكة تقليدية ودوائر ناعمة لتحويل العرض إلى تمرير أفقي بالسحب.",
          "options": [
            {
              "value": "false",
              "label": "إيقاف"
            },
            {
              "value": "true",
              "label": "تفعيل"
            }
          ],
          "default": "false"
        },
        "category_scope": {
          "type": "category_scope",
          "label": "أقسام العرض",
          "description": "اضغط للاختيار: كل الأقسام، أو التي تحتوي منتجات فقط، أو أقسام محددة من القائمة.",
          "default": {
            "mode": "all",
            "categoryIds": []
          }
        }
      }
    },
    {
      "id": "featured_products",
      "name": "منتجات مميزة",
      "component": "FEATURED_PRODUCTS",
      "group": "template_group",
      "contentSchema": {
        "color_scheme": {
          "type": "select",
          "label": "مخطط الألوان",
          "optionsFrom": "color_schemes",
          "default": "scheme-light"
        },
        "title": {
          "type": "text",
          "label": "العنوان",
          "default": "قطع معمارية"
        },
        "subtitle": {
          "type": "text",
          "label": "العنوان الفرعي",
          "default": "وصل حديثاً"
        },
        "layout_style": {
          "type": "select",
          "label": "نمط العرض",
          "options": [
            {
              "value": "grid",
              "label": "شبكة (Grid)"
            },
            {
              "value": "minimal_list",
              "label": "قائمة فاخرة (Minimal)"
            }
          ],
          "default": "grid"
        },
        "items_per_row": {
          "type": "select",
          "label": "عدد العناصر في الصف (للشبكة)",
          "options": [
            {
              "value": "2",
              "label": "2"
            },
            {
              "value": "3",
              "label": "3"
            },
            {
              "value": "4",
              "label": "4"
            }
          ],
          "default": "4"
        },
        "padding_top": {
          "type": "text",
          "label": "الهامش العلوي",
          "default": "100px"
        },
        "padding_bottom": {
          "type": "text",
          "label": "الهامش السفلي",
          "default": "100px"
        },
        "category_scope": {
          "type": "category_scope",
          "label": "نطاق الأقسام",
          "description": "ما المنتجات التي تُعرض: كل الأقسام، أو أقسام بها منتجات فقط، أو أقسام تختارها من القائمة.",
          "default": {
            "mode": "all",
            "categoryIds": []
          }
        },
        "show_category_tabs": {
          "type": "select",
          "label": "تبويب تصفية بالقسم (في الواجهة)",
          "description": "يظهر «الكل» وأقسام من المنتجات المعروضة لتصفية سريعة. يُنصح بإخفائه إن لم ترد التبويبات.",
          "options": [
            {
              "value": "true",
              "label": "إظهار عند وجود أكثر من قسم"
            },
            {
              "value": "false",
              "label": "إخفاء"
            }
          ],
          "default": "false"
        }
      }
    },
    {
      "id": "product_carousel",
      "name": "سلايدر منتجات",
      "component": "PRODUCT_CAROUSEL",
      "group": "template_group",
      "contentSchema": {
        "color_scheme": {
          "type": "select",
          "label": "مخطط الألوان",
          "optionsFrom": "color_schemes",
          "default": "scheme-light"
        },
        "title": {
          "type": "text",
          "label": "العنوان",
          "default": "منتجات مختارة"
        },
        "subtitle": {
          "type": "text",
          "label": "العنوان الفرعي",
          "default": "مختاراتنا لك"
        },
        "padding_top": {
          "type": "text",
          "label": "الهامش العلوي",
          "default": "100px"
        },
        "padding_bottom": {
          "type": "text",
          "label": "الهامش السفلي",
          "default": "100px"
        },
        "category_scope": {
          "type": "category_scope",
          "label": "نطاق الأقسام",
          "default": {
            "mode": "all",
            "categoryIds": []
          }
        }
      }
    },
    {
      "id": "newsletter",
      "name": "النشرة البريدية",
      "component": "NEWSLETTER",
      "group": "template_group",
      "contentSchema": {
        "color_scheme": {
          "type": "select",
          "label": "مخطط الألوان",
          "optionsFrom": "color_schemes",
          "default": "scheme-light"
        },
        "title": {
          "type": "text",
          "label": "العنوان",
          "default": "ابقَ على اطلاع"
        },
        "subtitle": {
          "type": "text",
          "label": "العنوان الفرعي"
        },
        "padding_top": {
          "type": "text",
          "label": "الهامش العلوي",
          "default": "100px"
        },
        "padding_bottom": {
          "type": "text",
          "label": "الهامش السفلي",
          "default": "100px"
        }
      }
    },
    {
      "id": "product_details",
      "name": "إعدادات صفحة المنتج (متقدم)",
      "component": "PRODUCT_DETAILS_SETTINGS",
      "group": "template_group",
      "contentSchema": {

        "color_scheme": {
          "type": "select",
          "label": "مخطط الألوان",
          "optionsFrom": "color_schemes",
          "default": "scheme-light"
        },
        "layout": {
          "type": "select",
          "label": "تخطيط الصفحة",
          "options": [
            {
              "value": "image_left",
              "label": "صورة يسار / تفاصيل يمين"
            },
            {
              "value": "image_right",
              "label": "صورة يمين / تفاصيل يسار"
            },
            {
              "value": "image_top",
              "label": "صورة في الأعلى / تفاصيل أسفل"
            }
          ],
          "default": "image_left"
        },
        "show_thumbnails": {
          "type": "select",
          "label": "إظهار صور مصغّرة",
